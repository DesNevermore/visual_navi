# Environment variables for API keys
# Copy this to .env and fill in your keys

# ============================================
# Speech-to-Text (语音转文字)
# ============================================
# Provider: "openai" (Whisper API)
SPEECH_TO_TEXT_PROVIDER=openai
SPEECH_TO_TEXT_API_KEY=your_openai_api_key_here
SPEECH_TO_TEXT_BASE_URL=https://api.openai.com/v1
SPEECH_TO_TEXT_MODEL=whisper-1
SPEECH_TO_TEXT_FALLBACK_MODELS=
SPEECH_TO_TEXT_LANGUAGE=en

# Alternative: Use OpenAI-compatible API (e.g., 国内中转)
# SPEECH_TO_TEXT_BASE_URL=https://your-proxy.com/v1

# GPT.GE OpenAI-compatible example:
# SPEECH_TO_TEXT_BASE_URL=https://api.gpt.ge/v1/
# SPEECH_TO_TEXT_MODEL=gemini-3-flash-preview
# SPEECH_TO_TEXT_FALLBACK_MODELS=
# The frontend records WAV so Gemini chat audio input can transcribe it.

# ============================================
# Vision Analysis (图片理解生成导航指令)
# ============================================
# Provider: "gemini" or "openai"
VISION_PROVIDER=gemini

# Option 1: Google Gemini (recommended, cheapest)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
# GEMINI_BASE_URL is not needed (uses official SDK)

# Option 2: OpenAI GPT-4o (if VISION_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4o-mini

# Alternative: Use OpenAI-compatible API
# OPENAI_BASE_URL=https://your-proxy.com/v1

# GPT.GE OpenAI-compatible example:
# VISION_PROVIDER=openai
# OPENAI_API_KEY=your_gpt_ge_api_key_here
# OPENAI_BASE_URL=https://api.gpt.ge/v1/
# OPENAI_VISION_MODEL=gemini-3-flash-preview
# If GPT.GE reports no Gemini channel, use OPENAI_VISION_MODEL=gpt-4o-mini

# ============================================
# Text-to-Speech (文字转语音) - Optional
# ============================================
# By default, uses browser's free speechSynthesis
# Set to "openai" to use cloud TTS (costs money)
TTS_PROVIDER=browser

# If TTS_PROVIDER=openai:
TTS_API_KEY=your_openai_api_key_here
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# OpenAI-compatible TTS example:
# TTS_PROVIDER=openai
# TTS_API_KEY=your_gpt_ge_api_key_here
# TTS_BASE_URL=https://api.v3.cm/v1
# TTS_MODEL=gemini-2.5-flash-preview-tts
# TTS_FALLBACK_MODELS=qwen-tts,qwen-tts-latest,qwen3-tts-flash,gemini-2.5-pro-preview-tts
# TTS_VOICE=Kore
# TTS_CONTENT_TYPE=audio/mpeg
# This uses POST /v1/audio/speech through the OpenAI-compatible provider.
